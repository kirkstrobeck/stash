#!/bin/bash

# Usage:
#   ./pr-feature
#   ./pr-feature -b target_branch
#   ./pr-feature --auto-merge
#   ./pr-feature -b main --auto-merge

target_branch=""
auto_merge=false

while [ $# -gt 0 ]; do
  case "$1" in
    -b)
      if [ -z "${2:-}" ]; then
        echo "error: -b requires a branch name" >&2
        exit 1
      fi
      target_branch=$2
      shift 2
      ;;
    --auto-merge)
      auto_merge=true
      shift
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

git push -u origin HEAD

pr_command="gh pr create --fill"

if [ "$auto_merge" != true ]; then
  pr_command+=" --draft"
fi

[ -n "$target_branch" ] && pr_command+=" -B $target_branch"

error_message=$($pr_command 2>&1)
create_status=$?

if [ $create_status -ne 0 ] && [ "$auto_merge" != true ]; then
  pr_command=${pr_command/--draft/}
  error_message=$($pr_command 2>&1)
  create_status=$?
fi

if [ $create_status -ne 0 ]; then
  echo "$error_message" >&2
  exit $create_status
fi

echo "$error_message"

if [ "$auto_merge" = true ]; then
  gh pr merge --auto --merge
fi

gh pr view --web
